# Normalize text files in Git and use LF consistently across platforms.
* text=auto

Dockerfile text eol=lf
*.dockerfile text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.toml text eol=lf
*.lock text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf

# Never attempt line-ending conversion or textual diffs for binary artifacts.
*.tif binary
*.tiff binary
*.png binary
*.jpg binary
*.jpeg binary
*.ckpt binary
*.pt binary
*.pth binary
*.safetensors binary
*.whl binary
*.tar binary
*.gz binary
*.tgz binary
*.zip binary

# Vendored model runtime is maintained from the recorded Prometheus commit.
src/prometheus/** linguist-vendored
